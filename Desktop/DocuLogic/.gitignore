__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.conda/
.anaconda/
# Ignore data files
*.ipynb
dataset/
# Ignore other user directories and system files
AppData/
Desktop/
Documents/
Downloads/
OneDrive/
Pictures/
Videos/
# Ignore devops and programming directories
devops/
programming/
# Ignore hidden system directories
.*
